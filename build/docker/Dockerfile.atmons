# -------- Stage 1: build mcrcon --------
FROM debian:stable-slim AS mcrcon-builder

RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates git build-essential \
 && update-ca-certificates

WORKDIR /src
RUN git clone --depth 1 https://github.com/Tiiffi/mcrcon.git
WORKDIR /src/mcrcon
RUN make

# -------- Stage 2: runtime image --------
FROM registry.access.redhat.com/ubi9/openjdk-21:latest
SHELL ["/bin/bash","-o","pipefail","-c"]
USER 0

LABEL org.opencontainers.image.source="https://github.com/FullMetal667/minecraft-gitops" \
      org.opencontainers.image.title="ATMONS Minecraft Server" \
      org.opencontainers.image.version="0.2.61" \
      org.opencontainers.image.vendor="chrisroth667" \
      org.opencontainers.image.licenses="MIT"

RUN microdnf install -y --setopt=install_weak_deps=0 \
      curl-minimal wget vim unzip nmap-ncat which ca-certificates \
 && microdnf clean all \
 && update-ca-trust

# --- Java 21 erzwingen ---
RUN set -euxo pipefail; \
    echo "[JAVA] Before fix:"; \
    java -version || true; \
    echo "JAVA_HOME=${JAVA_HOME:-}"; \
    microdnf -y remove java-17-openjdk java-17-openjdk-headless java-17-openjdk-devel || true; \
    microdnf clean all || true; \
    JAVA21_HOME="/usr/lib/jvm/java-21"; \
    if [[ ! -d "${JAVA21_HOME}" ]]; then \
      echo "[JAVA] ERROR: expected ${JAVA21_HOME} not found. Available JVMs:"; \
      ls -la /usr/lib/jvm || true; \
      exit 1; \
    fi; \
    alternatives --set java "${JAVA21_HOME}/bin/java" || true; \
    alternatives --set javac "${JAVA21_HOME}/bin/javac" || true; \
    ln -sf "${JAVA21_HOME}/bin/java" /usr/bin/java; \
    ln -sf "${JAVA21_HOME}/bin/javac" /usr/bin/javac || true; \
    echo "[JAVA] After fix:"; \
    /usr/bin/java -version; \
    echo "Resolved java: $(readlink -f /usr/bin/java)"; \
    echo "OK"

ENV JAVA_HOME=/usr/lib/jvm/java-21
ENV PATH="${JAVA_HOME}/bin:${PATH}"

# tini
ENV TINI_VERSION=v0.19.0
ADD https://github.com/krallin/tini/releases/download/${TINI_VERSION}/tini-amd64 /usr/local/bin/tini
RUN chmod +x /usr/local/bin/tini && ln -s /usr/local/bin/tini /usr/bin/tini

# mcrcon
COPY --from=mcrcon-builder --chmod=0755 --chown=0:0 /src/mcrcon/mcrcon /usr/local/bin/mcrcon

# startscript + eula
COPY atmons/startserver.sh /data/startserver.sh
COPY atmons/eula.txt      /data/eula.txt

ENV APP_DIR=/opt/atmons \
    DATA_DIR=/data

RUN mkdir -p "${APP_DIR}" "${DATA_DIR}"

# ---- WICHTIG: kein Modpack Download/Unzip im Build mehr ----

# OpenShift-kompatible Rechte (arbitrary UID)
RUN chgrp -R 0 "${APP_DIR}" "${DATA_DIR}" /data/startserver.sh /usr/local/bin/mcrcon \
 && chmod -R g=u "${APP_DIR}" "${DATA_DIR}" \
 && chmod g=u /data/startserver.sh /usr/local/bin/mcrcon \
 && find "${APP_DIR}" -type d -exec chmod g+s {} \; \
 && find "${DATA_DIR}" -type d -exec chmod g+s {} \;

WORKDIR /data
VOLUME ["/data"]
EXPOSE 25565/tcp

ENTRYPOINT ["/usr/local/bin/tini","--"]
CMD ["/data/startserver.sh"]