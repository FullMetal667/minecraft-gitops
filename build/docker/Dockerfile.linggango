# -------- Stage 1: build mcrcon --------
FROM debian:stable-slim AS mcrcon-builder

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates git build-essential \
 && update-ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN git clone --depth 1 https://github.com/Tiiffi/mcrcon.git
WORKDIR /src/mcrcon
RUN make


# -------- Stage 2: runtime image --------
FROM registry.access.redhat.com/ubi9/openjdk-17:latest
SHELL ["/bin/bash","-o","pipefail","-c"]
USER 0

# Tools für Build/Runtime
RUN microdnf -y install \
      python3 python3-pip \
      curl-minimal unzip \
      which nmap-ncat \
    && microdnf clean all

# Python deps
RUN pip3 install --no-cache-dir requests

# mcrcon rein
COPY --from=mcrcon-builder --chmod=0755 --chown=0:0 /src/mcrcon/mcrcon /usr/local/bin/mcrcon

# Build context
WORKDIR /work
COPY linggango/tools/ /work/tools/

# Zielpfad im Image (immutable)
ENV MC_HOME=/srv/mc
RUN mkdir -p "${MC_HOME}/mods" "${MC_HOME}/config" "${MC_HOME}/defaultconfigs"

# Forge installieren
ARG MC_VERSION=1.20.1
ARG FORGE_VERSION=47.4.0
RUN curl -fsSL -o /tmp/forge-installer.jar \
      "https://maven.minecraftforge.net/net/minecraftforge/forge/${MC_VERSION}-${FORGE_VERSION}/forge-${MC_VERSION}-${FORGE_VERSION}-installer.jar" \
  && cd "${MC_HOME}" \
  && java -jar /tmp/forge-installer.jar --installServer \
  && rm -f /tmp/forge-installer.jar

# ----------------------------
# Modpack ZIP ins Image legen (aus FILE_ID + ZIP)
# ----------------------------
ARG FILE_ID
ARG ZIP
ARG MOD_NAME
ARG IMAGE_TAG

RUN set -euo pipefail; \
    if [[ -z "${FILE_ID:-}" ]]; then \
      echo "[BUILD] FILE_ID not set -> skipping modpack zip download"; exit 0; \
    fi; \
    DIR1=$(( FILE_ID / 1000 )); \
    DIR2=$(( FILE_ID % 1000 )); \
    if [[ -z "${ZIP}" ]]; then \
      if [[ -n "${MOD_NAME}" && -n "${IMAGE_TAG}" ]]; then \
        ZIP="${MOD_NAME}-${IMAGE_TAG}.zip"; \
      else \
        echo "[BUILD] ZIP not set and MOD_NAME/IMAGE_TAG missing -> skipping"; exit 0; \
      fi; \
    fi; \
    MODPACK_ZIP_URL="https://mediafilez.forgecdn.net/files/${DIR1}/${DIR2}/${ZIP}"; \
    echo "[BUILD] Downloading modpack zip: ${MODPACK_ZIP_URL}"; \
    curl -fL --retry 3 --retry-delay 2 -A "mc-gitops/1.0" -o "${MC_HOME}/mods/${ZIP}" "${MODPACK_ZIP_URL}"; \
    ls -lh "${MC_HOME}/mods/${ZIP}"


# EULA im Image
RUN echo "eula=true" > "${MC_HOME}/eula.txt"

# OpenShift arbitrary UID kompatibel
RUN chgrp -R 0 "${MC_HOME}" /usr/local/bin/mcrcon \
 && chmod -R g=u "${MC_HOME}" \
 && chmod g=u /usr/local/bin/mcrcon \
 && find "${MC_HOME}" -type d -exec chmod g+s {} \;

WORKDIR "${MC_HOME}"
