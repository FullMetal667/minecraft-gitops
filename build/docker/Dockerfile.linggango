# -------- Stage 1: build mcrcon --------
FROM debian:stable-slim AS mcrcon-builder

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates git build-essential \
 && update-ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /src
RUN git clone --depth 1 https://github.com/Tiiffi/mcrcon.git
WORKDIR /src/mcrcon
RUN make


# -------- Stage 2: runtime image --------
FROM registry.access.redhat.com/ubi9/openjdk-17:latest
SHELL ["/bin/bash","-o","pipefail","-c"]
USER 0

# Runtime tools
RUN microdnf -y install \
      python3 python3-pip \
      curl-minimal unzip \
      which nmap-ncat \
    && microdnf clean all

# Python deps (for manifest download)
RUN pip3 install --no-cache-dir requests

# mcrcon binary
COPY --from=mcrcon-builder --chmod=0755 --chown=0:0 /src/mcrcon/mcrcon /usr/local/bin/mcrcon

# helper tools/scripts
WORKDIR /work
COPY linggango/tools/ /work/tools/

# Base path in image
ENV MC_HOME=/srv/mc
RUN mkdir -p "${MC_HOME}/mods" "${MC_HOME}/config" "${MC_HOME}/defaultconfigs"

# (Optional) create runtime volume layout (won't persist if /data is a mounted volume)
RUN mkdir -p /data/forge/mods

# ----------------------------
# Modpack ZIP ins Image legen (aus FILE_ID + ZIP) und standardisieren
# Ergebnis: /srv/mc/mods/Linggango.zip
# ----------------------------
ARG FILE_ID
ARG ZIP=""

RUN set -euo pipefail; \
    if [[ -z "${FILE_ID:-}" || -z "${ZIP:-}" ]]; then \
      echo "[BUILD] FILE_ID/ZIP not set -> skipping modpack zip download"; \
      exit 0; \
    fi; \
    DIR1=$(( FILE_ID / 1000 )); \
    DIR2=$(( FILE_ID % 1000 )); \
    echo "[BUILD] Downloading modpack zip: ${ZIP} (FILE_ID=${FILE_ID} -> ${DIR1}/${DIR2})"; \
    ok="false"; \
    for HOST in mediafilez.forgecdn.net media.forgecdn.net edge.forgecdn.net; do \
      URL="https://${HOST}/files/${DIR1}/${DIR2}/${ZIP}"; \
      echo "[BUILD] Trying: ${URL}"; \
      if curl -fL --retry 2 --retry-delay 2 \
        -A "Mozilla/5.0" \
        -H "Referer: https://www.curseforge.com/" \
        -H "Accept: */*" \
        -o "${MC_HOME}/mods/Linggango.zip.new" "${URL}"; then \
          mv -f "${MC_HOME}/mods/Linggango.zip.new" "${MC_HOME}/mods/Linggango.zip"; \
          ls -lh "${MC_HOME}/mods/Linggango.zip"; \
          ok="true"; \
          break; \
      fi; \
    done; \
    if [[ "${ok}" != "true" ]]; then \
      echo "[BUILD] ERROR: could not download modpack zip during build (403/other)."; \
      exit 22; \
    fi

# EULA in image
RUN echo "eula=true" > "${MC_HOME}/eula.txt"

# OpenShift arbitrary UID compatible perms
RUN chgrp -R 0 "${MC_HOME}" /usr/local/bin/mcrcon \
 && chmod -R g=u "${MC_HOME}" \
 && chmod g=u /usr/local/bin/mcrcon \
 && find "${MC_HOME}" -type d -exec chmod g+s {} \;

WORKDIR "${MC_HOME}"
